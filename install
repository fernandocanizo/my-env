#!/usr/bin/env bash
set -euo pipefail

baseFolder=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)
dryRun=false
shellOverride=""
displayOverride=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --shell=*) shellOverride="${1#*=}"; shift ;;
    --display=*) displayOverride="${1#*=}"; shift ;;
    --dry-run) dryRun=true; shift ;;
    --help|-h)
      cat <<'HELP'
Usage: ./install [--shell=SHELL] [--display=DISPLAY] [--dry-run]

Options:
  --shell=bash|fish|xonsh|zsh    Override auto-detected shell
  --display=x11|wayland|cli      Override auto-detected display server
  --dry-run                      Show what would be done, change nothing
  --help, -h                     Show this help

Auto-detection:
  Shell:  derived from $SHELL
  Display: wayland if $WAYLAND_DISPLAY is set,
           x11 if $DISPLAY is set,
           cli otherwise
  Host:   always $HOSTNAME (not overridable)
HELP
      exit 0
      ;;
    *) echo "Unknown option: $1"; exit 1 ;;
  esac
done

# --- Auto-detect ---
if [[ -n "$shellOverride" ]]; then
  detectedShell="$shellOverride"
else
  detectedShell=$(basename "$SHELL")
fi

if [[ -n "$displayOverride" ]]; then
  detectedDisplay="$displayOverride"
elif [[ -n "${WAYLAND_DISPLAY:-}" ]]; then
  detectedDisplay="wayland"
elif [[ -n "${DISPLAY:-}" ]]; then
  detectedDisplay="x11"
else
  detectedDisplay="cli"
fi

host="$HOSTNAME"

# --- Helper: idempotent symlink ---
myLink() {
  local src="$1" dst="$2"
  if $dryRun; then
    echo "[DRY-RUN] ln -sfT $src $dst"
    return 0
  fi
  if [[ -L "$dst" ]]; then
    local current
    current=$(readlink "$dst") || true
    if [[ "$current" != "$src" ]]; then
      rm -f "$dst"
    fi
  elif [[ -e "$dst" && ! -L "$dst" ]]; then
    echo "WARNING: $dst exists and is not a symlink, skipping"
    return 0
  fi
  ln -sfT "$src" "$dst"
}

# --- Ensure host folder exists (for new machines) ---
hostBashDir="${baseFolder}/host/${host}/bash/autoload"
if [[ ! -d "$hostBashDir" ]]; then
  echo "Creating host folder: host/${host}/..."
  if ! $dryRun; then
    mkdir -p "$hostBashDir"
    touch "${baseFolder}/host/${host}/bash/autoload/.gitkeep"
  fi
fi

cd "$HOME" || exit 1

# 1. Universal dotfiles
echo "Linking universal dotfiles..."
for f in dircolors gitconfig iex.exs npmrc pgpass plan profile project psqlrc pylintrc user-dirs.dirs; do
  [[ -f "${baseFolder}/home/$f" ]] && myLink "${baseFolder}/home/$f" ".$f"
done

# 2. Env folder marker
if ! $dryRun; then
  echo "${baseFolder}" >| "${HOME}/.envFolder"
fi

# 3. Shell-specific configs
case "$detectedShell" in
  bash)
    echo "Configuring bash..."
    for f in bashrc bash_profile bash_logout inputrc; do
      myLink "${baseFolder}/host/common/bash/$f" ".$f"
    done
    ;;
  xonsh)
    echo "Configuring xonsh..."
    myLink "${baseFolder}/host/common/xonsh/xonshrc" ".xonshrc"
    ;;
  fish)
    echo "Configuring fish... (no configs yet, placeholder only)"
    ;;
  zsh)
    echo "Configuring zsh... (no configs yet, placeholder only)"
    ;;
  *)
    echo "Unknown shell: $detectedShell"; exit 1
    ;;
esac

# 4. Display-specific home dotfiles
case "$detectedDisplay" in
  x11)
    echo "Configuring X11..."
    for f in xprofile Xresources; do
      [[ -f "${baseFolder}/display/x11/home/$f" ]] && myLink "${baseFolder}/display/x11/home/$f" ".$f"
    done
    ;;
  wayland)
    echo "Configuring Wayland..."
    ;;
  cli)
    echo "Configuring CLI/headless..."
    ;;
esac

# 5. Ensure ~/.config exists
if [[ ! -d "${HOME}/.config" ]]; then
  if ! $dryRun; then mkdir -p "${HOME}/.config"; fi
fi

# 6. Generic app configs (display-agnostic)
echo "Linking generic app configs..."
for app in git kitty wezterm yay; do
  [[ -d "${baseFolder}/app/$app" ]] && myLink "${baseFolder}/app/$app" "${HOME}/.config/$app"
done

# 7. Display-specific app configs
case "$detectedDisplay" in
  x11)
    for app in i3; do
      [[ -d "${baseFolder}/display/x11/app/$app" ]] && myLink "${baseFolder}/display/x11/app/$app" "${HOME}/.config/$app"
    done
    ;;
  wayland)
    for app in wayland; do
      [[ -d "${baseFolder}/display/wayland/app/$app" ]] && myLink "${baseFolder}/display/wayland/app/$app" "${HOME}/.config/$app"
    done
    ;;
esac

echo "Done."
