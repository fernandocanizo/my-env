# Find biggest directories (numeric)
find-biggest-dirs() {
  if [[ -z $1 ]]; then
    echo "Please provide a path to search"
    return 0
  fi
  sudo du --one-file-system --summarize "$1"/* | /usr/bin/env sort --numeric-sort --reverse
}

# Find biggest directories (human-readable)
find-biggest-dirs-h() {
  if [[ -z $1 ]]; then
    echo "Please provide a path to search"
    return 0
  fi
  sudo du --human-readable --summarize --one-file-system "$1"/* | sort --human-numeric-sort --reverse
}

# Find biggest files (uses sudo when no path given)
find-biggest-files() {
  if [[ -z $1 ]]; then
    sudo find / -xdev -type f -printf "%s %p\n" | sort --numeric-sort --reverse | head -n 20 | numfmt --to=iec
  else
    find "$1" -xdev -type f -printf "%s %p\n" | sort --numeric-sort --reverse | head -n 20 | numfmt --to=iec
  fi
}
