#!/usr/bin/env bash
# ~/.bashrc — interactive non-login shell configuration
#
# Structure:
#   1. Early exit for non-interactive shells
#   2. PATH (from host/<hostname>/autoload/path.sh)
#   3. Omarchy environment (copied to host/common/bash/omarchy/envs.sh)
#   4. User autoload system (common + host-specific scripts)
#      - Includes: GBT prompt, eternal history, ssh-agent, functions, etc.
#   5. Consolidated aliases (from host/<hostname>/bash/alias.sh)
#   6. Omarchy functions (copied to host/common/bash/omarchy/fns/)
#   7. Omarchy init: mise, zoxide, fzf (starship explicitly dropped)
#   8. User extras: fnm, fastfetch (login shells only)

# If not running interactively, don't do anything
[[ $- != *i* ]] && return

# --- 2. PATH ---
source "$HOME/.my-env/host/cygnus/bash/autoload/path.sh"

# --- 3. Omarchy environment ---
source "$HOME/.my-env/host/common/bash/omarchy/envs.sh"

# --- 4. User autoload system ---
read baseFolder < ~/.envFolder 2>/dev/null
[[ -z "$baseFolder" ]] && baseFolder="$HOME/.my-env"

autoload="${baseFolder}/host/common/bash/autoload/*.sh"
thisHostScriptsFolder="${baseFolder}/host/$HOSTNAME/bash/autoload"
thisHost="${thisHostScriptsFolder}/*.sh"
test -d "${thisHostScriptsFolder}" || mkdir -p "${thisHostScriptsFolder}"
completions="${baseFolder}/host/common/bash/completions"

for file in $(/usr/bin/env ls -1 ${autoload} 2>/dev/null); do
  source "${file}"
done

for file in $(/usr/bin/env ls -1 ${thisHost} 2>/dev/null); do
  source "${file}"
done

# bash-completion (global)
[[ -z "$BASH_COMPLETION" ]] && [[ -r /etc/bash_completion ]] && source /etc/bash_completion

# thisHost completions
for file in $(/usr/bin/env ls -1 ${completions} 2>/dev/null); do
  source "${completions}/${file}"
done

# --- 5. Consolidated aliases ---
[[ -f "${baseFolder}/host/cygnus/bash/alias.sh" ]] && source "${baseFolder}/host/cygnus/bash/alias.sh"

# --- 6. Omarchy functions ---
for f in "$HOME/.my-env/host/common/bash/omarchy/fns/"*; do
  [[ -f "$f" ]] && source "$f"
done

# --- 7. Omarchy init (mise, zoxide, fzf; starship dropped) ---
if command -v mise &> /dev/null; then
  eval "$(mise activate bash)"
fi

if command -v zoxide &> /dev/null; then
  eval "$(zoxide init bash)"
fi

if command -v fzf &> /dev/null; then
  [[ -f /usr/share/fzf/completion.bash ]] && source /usr/share/fzf/completion.bash
  [[ -f /usr/share/fzf/key-bindings.bash ]] && source /usr/share/fzf/key-bindings.bash
fi

# omarchy completions
[[ -f "$HOME/.my-env/host/common/bash/omarchy/completions" ]] && source "$HOME/.my-env/host/common/bash/omarchy/completions"

# --- 8. User extras ---
eval "$(fnm env --use-on-cd --shell bash)"

# readline config
[[ -f "$HOME/.my-env/host/common/bash/inputrc" ]] && bind -f "$HOME/.my-env/host/common/bash/inputrc"

# fastfetch only on login shells, not every new terminal
if shopt -q login_shell; then
  fastfetch -l garuda 2>/dev/null || true
fi
